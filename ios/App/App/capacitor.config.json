{
	"appId": "com.guber.app",
	"appName": "GUBER",
	"webDir": "dist/public",
	"server": {
		"url": "https://guberapp.app",
		"cleartext": false
	},
	"plugins": {
		"Browser": {
			"presentationStyle": "popover"
		},
		"GoogleAuth": {
			"scopes": [
				"profile",
				"email"
			],
			"serverClientId": "531752155183-san326hto8ngq4km75gr7hnid1gmtt0u.apps.googleusercontent.com",
			"forceCodeForRefreshToken": true
		}
	},
	"ios": {
		"scheme": "guber",
		"contentInset": "automatic"
	},
	"android": {
		"allowMixedContent": false,
		"minWebViewVersion": 60
	},
	"packageClassList": [
		"BiometricAuthNative",
		"AppPlugin",
		"CAPBrowserPlugin",
		"PreferencesPlugin",
		"GoogleAuth"
	]
}
