<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="guberapp.app" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="guber" />
            </intent-filter>

        </activity>

        <!-- Live-task foreground location service.
             foregroundServiceType="location" satisfies Android 14+ (API 34)
             requirements for the FOREGROUND_SERVICE_LOCATION permission. -->
        <service
            android:name=".GuberTrackingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Default FCM notification channel used on cold-boot before JS runs -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="guber_default" />

    </application>

    <!-- ── Network ───────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Location ──────────────────────────────────────────────────────── -->
    <!-- Foreground precise and coarse location for map display and job matching -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Background location: active only while GuberTrackingService is running
         during an accepted job (worker shares position with hirer in real time).
         Requested at runtime after foreground location is already granted. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ── Foreground Service (Android 9+ / Android 14+) ─────────────────── -->
    <!-- Required to start any foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 14+ for a foreground service declared with
         foregroundServiceType="location" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- ── Camera ────────────────────────────────────────────────────────── -->
    <!-- Used for job photo capture, Verify & Inspect, and hands-free POV mode -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- ── Microphone ────────────────────────────────────────────────────── -->
    <!-- Used by JAC (GUBER AI voice assistant) for voice input -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- ── Notifications ─────────────────────────────────────────────────── -->
    <!-- Required on Android 13+ to display push notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── Hardware features ─────────────────────────────────────────────── -->
    <!-- GPS preferred; falls back to network location on devices without GPS -->
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

</manifest>
