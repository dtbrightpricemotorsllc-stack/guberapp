# GUBER Environment Variables
# Copy this file to .env and fill in all values marked REQUIRED.
# Values marked OPTIONAL can be left blank to disable that feature.
# Never commit actual secrets to version control.

# ─── Core ────────────────────────────────────────────────────────────────────

# REQUIRED. postgresql:// connection string.
# Replit: auto-set when a PostgreSQL database is attached.
# Other: Neon, Supabase, Railway, etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# REQUIRED. Node environment. Must be "production" in prod — enables rate
# limiting, HTTPS-only cookies, OAuth durable nonce store, APNs live push.
NODE_ENV=production

# REQUIRED in production. Random 64-byte hex secret for express-session signing.
# Generate: openssl rand -hex 64
SESSION_SECRET=

# OPTIONAL. Server port. Defaults to 5000.
PORT=5000

# OPTIONAL. Full base URL of the server (e.g. https://guberapp.app).
# Required for Google OAuth callback and ExternalPurchaseSheet token redirect.
APP_BASE_URL=https://guberapp.app

# Alias used in some older code paths. Same value as APP_BASE_URL.
APP_URL=https://guberapp.app

# ─── Stripe (Main Account — Studio credits, Trust Box, Business, etc.) ──────

# REQUIRED. Stripe secret key (sk_live_... or sk_test_...).
STRIPE_SECRET_KEY=sk_live_...

# REQUIRED. Stripe webhook signing secret for /api/webhooks/stripe.
# Create at Stripe Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...

# REQUIRED. Price ID for the Trust Box Payroll subscription product.
# Find in Stripe Dashboard → Products → Trust Box.
STRIPE_PAYROLL_TRUST_BOX_PRICE_ID=price_...

# ─── Stripe Connect (Job payments, worker payouts) ───────────────────────────

# REQUIRED. Stripe Connect platform secret key (usually same as STRIPE_SECRET_KEY
# for the platform account, but set separately for clarity and rotation safety).
STRIPE_CONNECT_SECRET_KEY=sk_live_...

# REQUIRED. Webhook signing secret for /api/webhooks/stripe-connect.
# Create a separate Connect webhook in Stripe Dashboard.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# ─── Google Auth & Maps ──────────────────────────────────────────────────────

# REQUIRED for Google Sign-In (web OAuth flow).
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# REQUIRED for Google Sign-In on Android native.
GOOGLE_ANDROID_CLIENT_ID=...apps.googleusercontent.com

# Frontend Google Maps API key (browser-restricted, served via /api/config).
# Also set as VITE_GOOGLE_MAPS_API_KEY for local dev.
GOOGLE_MAPS_API_KEY=AIza...
VITE_GOOGLE_MAPS_API_KEY=AIza...

# Google Maps Geocoding API key (server-side only, no HTTP-referer restriction).
GOOGLE_GEOCODING_API_KEY=AIza...

# Web client ID for Google Sign-In on the frontend.
VITE_GOOGLE_WEB_CLIENT_ID=...apps.googleusercontent.com

# ─── Apple Push Notifications (APNs) ────────────────────────────────────────

# REQUIRED for iOS push notifications.
# Key ID from Apple Developer Portal → Keys → APNs key.
APNS_KEY_ID=

# 10-character Apple Team ID from Apple Developer Portal.
APNS_TEAM_ID=

# Contents of the .p8 private key file (include -----BEGIN PRIVATE KEY----- lines).
APNS_PRIVATE_KEY=

# iOS bundle ID. Must match capacitor.config.ts.
APNS_BUNDLE_ID=com.guber.app

# Apple Developer Team ID (same as APNS_TEAM_ID, used in some OAuth flows).
APPLE_TEAM_ID=

# ─── VAPID (Web Push Notifications) ─────────────────────────────────────────

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:support@guberapp.app

# ─── Firebase (Android Push Notifications via FCM) ──────────────────────────

# JSON content of the Firebase Admin SDK service account key file.
# Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ─── Cloudinary (Media storage — profile photos, proof uploads, V&I clips) ──

# REQUIRED for any photo/video upload feature.
# Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── AI / Media Generation ───────────────────────────────────────────────────

# REQUIRED for GUBER Studio (video/image generation).
# Without this, /api/studio/generate/* returns 503 without deducting credits.
FAL_KEY=

# OpenAI — used for content moderation and AI-or-Not detection.
# Provided via Replit AI integration (preferred) or set manually.
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Hugging Face token (optional, used for some AI-or-Not model calls).
HF_TOKEN=

# ─── Email (Resend) ──────────────────────────────────────────────────────────

# REQUIRED for transactional email (verification, password reset, notifications).
RESEND_API_KEY=re_...

# The From domain must be verified in Resend.
RESEND_FROM_DOMAIN=guberapp.app

# ─── Security ────────────────────────────────────────────────────────────────

# REQUIRED for Verified Release System release codes (HMAC signing).
# Generate: openssl rand -hex 64. Must be stable — changing it invalidates
# all existing release codes.
RELEASE_CODE_SECRET=

# REQUIRED for mobile checkout token bridge and wearable token endpoints.
GUBER_SHARED_SECRET=

# JWT secret for wearable / hands-free token signing.
JWT_SECRET=

# ─── Cron & Background Jobs ──────────────────────────────────────────────────

# REQUIRED in production Autoscale. Set to "true" to disable in-process
# node-cron timers. Use an external scheduler to POST to /api/internal/cron/run.
DISABLE_BACKGROUND_JOBS=true

# Random secret for authenticating cron trigger and Mission Control endpoints.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Studio Tools ────────────────────────────────────────────────────────────

# Cache TTL for studio tool pricing table (milliseconds). Default: 60000.
STUDIO_TOOLS_CACHE_TTL_MS=60000

# ─── Codemagic (iOS CI/CD — set in Codemagic environment, not here) ─────────
# These are documented here for reference only. Set them in Codemagic's
# "Default" environment group, not in the app's runtime environment.
#
# APP_STORE_CONNECT_ISSUER_ID=
# APP_STORE_CONNECT_KEY_IDENTIFIER=
# APP_STORE_CONNECT_PRIVATE_KEY=  (contents of AuthKey_XXXXXX.p8)
